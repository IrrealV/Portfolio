---
import Section from '../ui/Section.astro';
import TechIcon from '../icons/TechIcon.astro';
import { ABOUT, LANGUAGES } from '../../data';

const visibleLanguages = LANGUAGES.filter(
  (language) => Boolean(language.name?.trim()) && Boolean(language.level?.trim()),
);

/**
 * About section - 3 columns with representative icons
 */
---

<Section title="Sobre mí" id="about">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Column 1: Introduction -->
    <div class="flex flex-col">
      <p class="text-(--color-text-secondary) leading-relaxed text-lg flex-1">
        {ABOUT.intro}
      </p>
      <div class="flex items-center justify-center gap-4 mt-6 pt-4">
        <span class="text-2xl" title="Estudiante">📚</span>
        <span class="text-2xl font-mono text-(--color-accent)" title="Terminal"
          >&gt;_</span
        >
        <span class="text-2xl" title="Fullstack">⚡</span>
      </div>
    </div>

    <!-- Column 2: Experience -->
    <div class="flex flex-col">
      <p class="text-(--color-text-secondary) leading-relaxed text-lg flex-1">
        {ABOUT.experience}
      </p>
      <div class="flex items-center justify-center gap-4 mt-6 pt-4">
        <div class="w-8 h-8 flex items-center justify-center" title="Angular">
          <TechIcon name="Angular" class="w-6 h-6 text-red-600" />
        </div>
        <div class="w-8 h-8 flex items-center justify-center" title="NestJS">
          <TechIcon name="NestJS" class="w-6 h-6 text-red-500" />
        </div>
        <div class="w-8 h-8 flex items-center justify-center" title="Astro">
          <TechIcon name="Astro" class="w-6 h-6 text-orange-500" />
        </div>
      </div>
    </div>

    <!-- Column 3: Goals -->
    <div class="flex flex-col">
      <p class="text-(--color-text-secondary) leading-relaxed text-lg flex-1">
        {ABOUT.goals}
      </p>
      <div class="flex items-center justify-center gap-4 mt-6 pt-4">
        <span class="text-2xl" title="Escalabilidad">📈</span>
        <span class="text-2xl" title="Valor">💎</span>
        <span class="text-2xl" title="Mejora continua">🚀</span>
      </div>
    </div>
  </div>

  {
    visibleLanguages.length > 0 && (
      <div class="mt-8 pt-6">
        <h3 class="text-lg font-semibold text-(--color-text) mb-4">Idiomas</h3>
        <ul class="flex flex-wrap gap-3">
          {visibleLanguages.map((language) => (
            <li class="px-3 py-2 rounded-xl border border-(--color-border) text-sm text-(--color-text-secondary)">
              <span class="font-medium text-(--color-text)">{language.name}</span>
              <span class="mx-2 text-(--color-border)">•</span>
              <span>{language.level}</span>
              {language.detail && (
                <span class="ml-2 text-(--color-text-muted)">
                  ({language.detail})
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )
  }
</Section>
